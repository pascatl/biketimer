# ── Keycloak ──────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=biketimer
KEYCLOAK_CLIENT_ID_FRONTEND=biketimer-frontend
KEYCLOAK_CLIENT_ID_BACKEND=biketimer-frontend
KEYCLOAK_CLIENT_ID=biketimer-frontend
# Keycloak admin credentials for in-app registration
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=your_admin_password

# ── Local PostgreSQL (managed by Docker) ──────────────────────
# DATABASE_URL is constructed automatically in docker-compose:
#   postgresql://<DB_USER>:<DB_PASSWORD>@db:5432/<DB_NAME>
DB_USER=biketimer
DB_PASSWORD=biketimer
DB_NAME=biketimer

# ── SMTP / E-Mail ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your@email.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=biketimer@example.com

# ── Frontend ──────────────────────────────────────────────────
# URL shown in invitation emails
FRONTEND_URL=http://localhost:5173

# ── Ports (optional overrides) ────────────────────────────────
# FRONTEND_PORT=5173   # dev only (Vite)
# BACKEND_PORT=8000    # dev only (FastAPI)
# PORT=80              # prod only (nginx)

# ── Web Push / VAPID (optional – leave empty to disable push) ─────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@biketimer.local
