# ── Application ──────────────────────────────────────────────
APP_NAME=
VITE_APP_NAME=

# ── Keycloak ──────────────────────────────────────────────────
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID_FRONTEND=
KEYCLOAK_CLIENT_ID_BACKEND=
KEYCLOAK_CLIENT_ID=
# Keycloak admin credentials for in-app registration
KEYCLOAK_ADMIN_USER=
KEYCLOAK_ADMIN_PASSWORD=

# ── Local PostgreSQL (managed by Docker) ──────────────────────
# DATABASE_URL is constructed automatically in docker-compose:
#   postgresql://<DB_USER>:<DB_PASSWORD>@db:5432/<DB_NAME>
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── SMTP / E-Mail ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USE_TLS=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Frontend ──────────────────────────────────────────────────
# URL shown in invitation emails
FRONTEND_URL=

# ── Ports (optional overrides) ────────────────────────────────
# FRONTEND_PORT=5173   # dev only (Vite)
# BACKEND_PORT=8000    # dev only (FastAPI)
# PORT=80              # prod only (nginx)

# ── Web Push / VAPID (optional – leave empty to disable push) ─────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=

# ── Weather (optional – leave empty to disable weather widget) ──────────
# Get a free API key at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=
